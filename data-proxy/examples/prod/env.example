# Copy to a private path (not the git tree), then:
#   set -a && source /secure/path/data-nexus.env && set +a
#   ./examples/prod/render-config.sh > /secure/path/gateway.toml
#
# All values below are placeholders — replace before use.

# Management plane
export DN_JWT_SECRET='replace-with-long-random-hmac-secret'
export DN_BREAK_GLASS_PASSWORD='replace-with-break-glass-password'

# MySQL backend (data plane)
export DN_MYSQL_HOST='127.0.0.1'
export DN_MYSQL_PORT='13306'
export DN_MYSQL_DATABASE='orders'
export DN_MYSQL_USER='app_ro'
export DN_MYSQL_PASSWORD='replace-mysql-password'

# PostgreSQL backend
export DN_PG_HOST='127.0.0.1'
export DN_PG_PORT='15433'
export DN_PG_DATABASE='analytics'
export DN_PG_USER='app_ro'
export DN_PG_PASSWORD='replace-pg-password'

# Optional OpenDAL cold archive (only when proxy built with --features audit-opendal
# and security.audit.opendal_scheme is s3 or oss). Prefer env over putting keys in TOML.
# export DN_OPENDAL_ACCESS_KEY_ID='replace-access-key'
# export DN_OPENDAL_SECRET_ACCESS_KEY='replace-secret-key'
# export DN_OPENDAL_SESSION_TOKEN=''          # optional STS
# export DN_OPENDAL_REGION='us-east-1'        # s3
# Aliyun OSS also accepts ALIBABA_CLOUD_ACCESS_KEY_ID / ALIBABA_CLOUD_ACCESS_KEY_SECRET.
